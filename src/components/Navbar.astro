---
import { translations } from "../data/translations";
const locale = Astro.currentLocale || "en";
const t = translations[locale as keyof typeof translations];
const isEs = locale === "es";
---

<header class="navbar">
  <div class="navbar-container">
    <a href="#" class="nav-logo" aria-label="Logo Home">
      <img src="/logo.svg" alt="Yael Caballero" class="logo-image" />
    </a>
    <nav class="nav-menu">
      <a href="#inicio" class="nav-link">{t["nav.start"]}</a>
      <a href="#proyectos" class="nav-link">{t["nav.projects"]}</a>
      <a href="#tecnologias" class="nav-link">{t["nav.tech"]}</a>
      <a href="#contacto" class="nav-link">{t["nav.contact"]}</a>
      
      <div class="lang-selector">
        <div class={`lang-slider ${isEs ? 'slide-es' : 'slide-en'}`}></div>
        <a href="/" class={`lang-btn ${!isEs ? 'active' : ''}`} data-lang="en">EN</a>
        <a href="/es" class={`lang-btn ${isEs ? 'active' : ''}`} data-lang="es">ES</a>
      </div>
    </nav>
  </div>
</header>

<script>
  // Save language preference on click
  const langBtns = document.querySelectorAll(".lang-btn");
  langBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const lang = btn.getAttribute("data-lang");
      if (lang) {
        localStorage.setItem("preferred-lang", lang);
      }
    });
  });

  // Global mouse coordinates tracking for cursor glow effect
  let ticking = false;

  const updateMouseGlow = (e: MouseEvent) => {
    if (!ticking) {
      window.requestAnimationFrame(() => {
        document.body.style.setProperty('--mouse-x', `${e.clientX}px`);
        document.body.style.setProperty('--mouse-y', `${e.clientY}px`);
        ticking = false;
      });
      ticking = true;
    }
  };

  document.body.classList.add('mouse-active');
  window.addEventListener('mousemove', updateMouseGlow);

  window.addEventListener('mouseenter', () => {
    document.body.classList.add('mouse-active');
  });

  window.addEventListener('mouseleave', () => {
    document.body.classList.remove('mouse-active');
  });

  // Active navigation link highlighting on scroll
  const navLinks = document.querySelectorAll(".nav-link");
  const sections = document.querySelectorAll("section");

  const highlightNav = () => {
    let scrollPos = window.scrollY + 120;
    
    sections.forEach((section) => {
      const id = section.getAttribute("id");
      if (!id) return;
      
      const top = section.offsetTop;
      const height = section.offsetHeight;

      if (scrollPos >= top && scrollPos < top + height) {
        navLinks.forEach((link) => {
          link.classList.remove("active");
          if (link.getAttribute("href") === `#${id}`) {
            link.classList.add("active");
          }
        });
      }
    });
  };

  window.addEventListener("scroll", highlightNav);
  window.addEventListener("load", highlightNav);
</script>

<style>
  .navbar {
    position: fixed;
    top: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 3rem);
    max-width: 900px;
    height: 64px;
    background: rgba(10, 10, 12, 0.7);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 99px;
    z-index: 1000;
    display: flex;
    align-items: center;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .navbar-container {
    width: 100%;
    padding: 0 1.25rem 0 0.75rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    display: flex;
    align-items: center;
  }

  .logo-image {
    height: 48px;
    width: 48px;
    display: block;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .logo-image:hover {
    transform: scale(1.08) rotate(5deg);
  }

  .nav-menu {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    position: relative;
    padding: 0.25rem 0;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 50%;
    transform: translateX(-50%) scaleX(0);
    width: 12px;
    height: 2px;
    background: var(--accent-gradient);
    border-radius: 99px;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-link:hover {
    color: var(--text-primary);
  }

  .nav-link.active {
    color: var(--text-primary);
    font-weight: 600;
  }

  .nav-link.active::after {
    transform: translateX(-50%) scaleX(1);
  }

  /* Language Selector Styles */
  .lang-selector {
    position: relative;
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 99px;
    padding: 2px;
    height: 32px;
    margin-left: 0.5rem;
  }

  .lang-slider {
    position: absolute;
    top: 2px;
    bottom: 2px;
    left: 2px;
    width: 32px;
    background: var(--accent-gradient);
    border-radius: 99px;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 4px 12px var(--accent-violet-glow);
    z-index: 1;
  }

  .lang-slider.slide-en {
    transform: translateX(0);
  }

  .lang-slider.slide-es {
    transform: translateX(32px);
  }

  .lang-btn {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 28px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    transition: color 0.3s ease;
  }

  .lang-btn:hover {
    color: var(--text-primary);
  }

  .lang-btn.active {
    color: #ffffff;
  }

  @media (max-width: 640px) {
    .navbar {
      top: 1rem;
      width: calc(100% - 1.5rem);
      height: 56px;
    }
    
    .logo-image {
      height: 40px;
      width: 40px;
    }

    .nav-menu {
      gap: 1rem;
    }

    .nav-link {
      font-size: 0.8rem;
    }

    .lang-selector {
      margin-left: 0.25rem;
    }
  }
</style>

