---
import { translations } from "../data/translations";
const locale = Astro.currentLocale || "en";
const t = translations[locale as keyof typeof translations];
const isEs = locale === "es";
---

<header class="navbar">
  <div class="navbar-container">
    <a href="#" class="nav-logo">
      <img src="/logo.svg" alt="Yael Caballero" class="logo-image" />
    </a>
    <nav class="nav-menu">
      <a href="#inicio" class="nav-link">{t["nav.start"]}</a>
      <a href="#proyectos" class="nav-link">{t["nav.projects"]}</a>
      <a href="#tecnologias" class="nav-link">{t["nav.tech"]}</a>
      <a href="#contacto" class="nav-link">{t["nav.contact"]}</a>
      
      <div class="lang-selector">
        <a href="/" class={`lang-btn ${!isEs ? 'active' : ''}`} data-lang="en">EN</a>
        <span class="lang-divider">|</span>
        <a href="/es" class={`lang-btn ${isEs ? 'active' : ''}`} data-lang="es">ES</a>
      </div>
    </nav>
  </div>
</header>

<script>
  // Save language preference on click
  const langBtns = document.querySelectorAll(".lang-btn");
  langBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const lang = btn.getAttribute("data-lang");
      if (lang) {
        localStorage.setItem("preferred-lang", lang);
      }
    });
  });
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 70px;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-color);
    z-index: 1000;
    display: flex;
    align-items: center;
  }

  .navbar-container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    display: flex;
    align-items: center;
  }

  .logo-image {
    height: 55px;
    width: 55px; /* Explicit width to prevent collapse */
    display: block;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .logo-image:hover {
    transform: scale(1.08);
  }

  .nav-menu {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-link {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .nav-link:hover {
    color: var(--text-primary);
  }

  /* Language Selector Styles */
  .lang-selector {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-muted);
    border-left: 1px solid var(--border-color);
    padding-left: 1.25rem;
    margin-left: 0.5rem;
  }

  .lang-btn {
    color: var(--text-muted);
    transition: color 0.2s ease;
  }

  .lang-btn:hover {
    color: var(--text-primary);
  }

  .lang-btn.active {
    color: var(--accent-violet-hover);
    text-shadow: 0 0 10px rgba(134, 116, 244, 0.3);
  }

  .lang-divider {
    opacity: 0.3;
    font-size: 0.75rem;
  }
</style>
