---
const email = "yisusscc@gmail.com";
const linkedinUrl = "https://linkedin.com/in/caballeroyael";
const githubUrl = "https://github.com/soyisuss";
---

<section id="contacto" class="contact-section">
  <div class="section-header">
    <h2 class="section-title">Contacto</h2>
    <p class="section-subtitle">
      ¿Tienes algún proyecto en mente, buscas incorporar talento de IA o simplemente quieres conectar? Hablemos.
    </p>
  </div>

  <div class="contact-container">
    <!-- Status & Info Card -->
    <div class="status-card">
      <div class="status-indicator">
        <span class="pulse-dot"></span>
        <span class="status-text">Disponible para ofertas y proyectos</span>
      </div>
      <h3 class="status-title">Trabajemos juntos</h3>
      <p class="status-desc">
        Actualmente estoy abierto a nuevas oportunidades como Ingeniero de IA, desarrollador de agentes autónomos y proyectos freelance. 
      </p>
      
      <div class="info-list">
        <div class="info-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="info-icon"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          <span>Estado de México (Abierto a remoto o presencial)</span>
        </div>
        <div class="info-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="info-icon"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          <span>Zona horaria: GMT-6 (CST)</span>
        </div>
      </div>
    </div>

    <!-- Contact Methods Grid -->
    <div class="methods-grid">
      <!-- Email Card -->
      <div class="method-card">
        <div class="method-icon-wrapper">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
        </div>
        <div class="method-info">
          <span class="method-label">Correo Electrónico</span>
          <span class="method-value" id="email-value">{email}</span>
        </div>
        <div class="method-actions">
          <a href={`mailto:${email}`} class="action-btn email-send-btn" aria-label="Enviar correo electrónico">
            Enviar
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
          </a>
          <button class="action-btn copy-btn" id="copy-email-btn" data-email={email} aria-label="Copiar correo al portapapeles">
            <span class="copy-btn-text">Copiar</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="copy-icon"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path></svg>
          </button>
        </div>
      </div>

      <!-- LinkedIn Card -->
      <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" class="method-card link-card">
        <div class="method-icon-wrapper linkedin-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"></circle></svg>
        </div>
        <div class="method-info">
          <span class="method-label">LinkedIn</span>
          <span class="method-value">in/caballeroyael</span>
        </div>
        <div class="card-arrow">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
        </div>
      </a>

      <!-- GitHub Card -->
      <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="method-card link-card">
        <div class="method-icon-wrapper github-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
        </div>
        <div class="method-info">
          <span class="method-label">GitHub</span>
          <span class="method-value">github.com/soyisuss</span>
        </div>
        <div class="card-arrow">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
        </div>
      </a>
    </div>
  </div>
</section>

<script>
  const copyBtn = document.getElementById("copy-email-btn");
  
  if (copyBtn) {
    copyBtn.addEventListener("click", () => {
      const email = copyBtn.getAttribute("data-email");
      if (email) {
        navigator.clipboard.writeText(email).then(() => {
          const btnText = copyBtn.querySelector(".copy-btn-text");
          const copyIcon = copyBtn.querySelector(".copy-icon");
          
          if (btnText) btnText.textContent = "¡Copiado!";
          if (copyIcon) {
            // Success checkmark SVG change
            copyIcon.innerHTML = '<polyline points="20 6 9 17 4 12"></polyline>';
          }
          
          copyBtn.classList.add("copied");

          setTimeout(() => {
            if (btnText) btnText.textContent = "Copiar";
            if (copyIcon) {
              copyIcon.innerHTML = '<rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path>';
            }
            copyBtn.classList.remove("copied");
          }, 2000);
        });
      }
    });
  }
</script>

<style>
  .contact-section {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .section-header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    position: relative;
    padding-bottom: 0.75rem;
  }

  .section-title::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 50px;
    height: 3px;
    background-color: var(--accent-violet);
    border-radius: 99px;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 600px;
  }

  .contact-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 900px) {
    .contact-container {
      grid-template-columns: 1.1fr 1fr;
    }
  }

  /* Status Card */
  .status-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.25rem;
    backdrop-filter: blur(10px);
  }

  .status-indicator {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(16, 185, 129, 0.05);
    border: 1px solid rgba(16, 185, 129, 0.15);
    padding: 0.4rem 0.85rem;
    border-radius: 99px;
    align-self: flex-start;
  }

  .pulse-dot {
    width: 8px;
    height: 8px;
    background-color: #10b981;
    border-radius: 50%;
    box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
    animation: pulse 1.6s infinite;
  }

  @keyframes pulse {
    0% {
      transform: scale(0.95);
      box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
    }
    70% {
      transform: scale(1);
      box-shadow: 0 0 0 8px rgba(16, 185, 129, 0);
    }
    100% {
      transform: scale(0.95);
      box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);
    }
  }

  .status-text {
    font-size: 0.8rem;
    font-weight: 600;
    color: #10b981;
    letter-spacing: 0.02em;
  }

  .status-title {
    font-size: 1.75rem;
    font-weight: 700;
  }

  .status-desc {
    color: var(--text-secondary);
    line-height: 1.65;
    font-size: 1rem;
  }

  .info-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1rem;
    border-top: 1px solid var(--border-color);
    padding-top: 1.5rem;
  }

  .info-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .info-icon {
    color: var(--accent-violet);
  }

  /* Methods Grid */
  .methods-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .method-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    backdrop-filter: blur(10px);
    text-decoration: none;
    color: inherit;
    position: relative;
  }

  .method-icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    transition: all 0.3s ease;
  }

  .method-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex-grow: 1;
  }

  .method-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    font-weight: 600;
  }

  .method-value {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    word-break: break-all;
  }

  .method-actions {
    display: flex;
    gap: 0.5rem;
  }

  .action-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.5rem 0.85rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .action-btn:hover {
    color: var(--text-primary);
    border-color: var(--accent-violet);
    background: rgba(134, 116, 244, 0.05);
  }

  .email-send-btn {
    background: rgba(134, 116, 244, 0.1);
    border-color: rgba(134, 116, 244, 0.2);
    color: var(--accent-violet-hover);
  }

  .email-send-btn:hover {
    background: var(--accent-violet);
    color: #ffffff;
    border-color: var(--accent-violet);
  }

  /* Interactive Link Cards */
  .link-card {
    cursor: pointer;
  }

  .link-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent-violet);
    box-shadow: 0 8px 24px var(--accent-violet-glow);
  }

  .link-card:hover .method-icon-wrapper {
    color: #ffffff;
    border-color: var(--accent-violet);
  }

  .link-card:hover .method-icon-wrapper.linkedin-icon {
    background: rgba(10, 102, 194, 0.15);
    color: #0a66c2;
  }

  .link-card:hover .method-icon-wrapper.github-icon {
    background: rgba(255, 255, 255, 0.08);
    color: #ffffff;
  }

  .card-arrow {
    color: var(--text-muted);
    opacity: 0.5;
    transition: all 0.3s ease;
  }

  .link-card:hover .card-arrow {
    opacity: 1;
    color: var(--accent-violet);
    transform: translate(2px, -2px);
  }

  .copied {
    background: rgba(16, 185, 129, 0.1) !important;
    border-color: rgba(16, 185, 129, 0.3) !important;
    color: #10b981 !important;
  }
</style>
