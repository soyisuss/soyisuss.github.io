---
interface Props {
  title: string;
  description: string;
  image?: string;
  tags: string[];
  githubUrl?: string;
  liveUrl?: string;
  status?: "completed" | "in-progress" | "upcoming";
}

const {
  title,
  description,
  image,
  tags,
  githubUrl,
  liveUrl,
  status = "completed",
} = Astro.props;

// Helper to determine badge text and styling
const getStatusBadge = (status: string) => {
  switch (status) {
    case "in-progress":
      return { text: "En desarrollo", class: "badge-progress" };
    case "upcoming":
      return { text: "Próximamente", class: "badge-upcoming" };
    default:
      return null;
  }
};

const badge = getStatusBadge(status);
---

<div class={`project-card ${status !== "completed" ? "card-dimmed" : ""}`}>
  <div class="card-image-container">
    {
      image ? (
        <img src={image} alt={title} class="project-image" loading="lazy" />
      ) : (
        <div class="project-gradient-placeholder">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="36"
            height="36"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="placeholder-icon"
          >
            <>
              <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z" />
              <path d="M12 8v8" />
              <path d="M8 12h8" />
            </>
          </svg>
        </div>
      )
    }
    {badge && <span class={`status-badge ${badge.class}`}>{badge.text}</span>}
  </div>

  <div class="card-content">
    <div class="card-header">
      <h3 class="project-title">{title}</h3>
    </div>

    <p class="project-desc">{description}</p>

    <div class="project-tags">
      {tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>

    <div class="project-links">
      {
        githubUrl && (
          <a
            href={githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="link-btn github-btn"
            aria-label="Ver código en GitHub"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <>
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                <path d="M9 18c-4.51 2-5-2-7-2" />
              </>
            </svg>
            Código
          </a>
        )
      }
      {
        liveUrl && status === "completed" && (
          <a
            href={liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="link-btn demo-btn"
            aria-label="Ver demo en vivo"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <>
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                <polyline points="15 3 21 3 21 9" />
                <line x1="10" y1="14" x2="21" y2="3" />
              </>
            </svg>
            Demo
          </a>
        )
      }
    </div>
  </div>
</div>

<style>
  .project-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    backdrop-filter: blur(10px);
  }

  .project-card:hover {
    transform: translateY(-6px);
    border-color: var(--accent-violet);
    box-shadow: 0 12px 30px var(--accent-violet-glow);
  }

  .card-dimmed {
    opacity: 0.85;
    border-style: dashed;
  }

  .card-dimmed:hover {
    opacity: 1;
    border-style: solid;
  }

  .card-image-container {
    position: relative;
    width: 100%;
    height: 200px;
    overflow: hidden;
    background: #0a0a0a;
  }

  .project-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-card:hover .project-image {
    transform: scale(1.05);
  }

  .project-gradient-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(
      135deg,
      rgba(134, 116, 244, 0.1) 0%,
      rgba(10, 10, 10, 0.8) 100%
    );
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-violet);
    transition: background 0.3s ease;
  }

  .project-card:hover .project-gradient-placeholder {
    background: linear-gradient(
      135deg,
      rgba(134, 116, 244, 0.15) 0%,
      rgba(10, 10, 10, 0.6) 100%
    );
  }

  .placeholder-icon {
    opacity: 0.6;
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
  }

  .project-card:hover .placeholder-icon {
    transform: scale(1.1);
    opacity: 1;
  }

  .status-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    padding: 0.35rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 99px;
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .badge-progress {
    background: rgba(245, 158, 11, 0.15);
    color: #fbbf24;
    border-color: rgba(245, 158, 11, 0.3);
  }

  .badge-upcoming {
    background: rgba(134, 116, 244, 0.15);
    color: var(--accent-violet-hover);
    border-color: rgba(134, 116, 244, 0.3);
  }

  .card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    gap: 1rem;
  }

  .project-title {
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.3;
    transition: color 0.3s ease;
  }

  .project-card:hover .project-title {
    color: var(--accent-violet);
  }

  .project-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.6;
    flex-grow: 1;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 500;
    background: rgba(255, 255, 255, 0.03);
    color: var(--text-muted);
    padding: 0.25rem 0.6rem;
    border-radius: 6px;
    border: 1px solid var(--border-color);
    transition: all 0.3s ease;
  }

  .project-card:hover .tag {
    border-color: rgba(134, 116, 244, 0.2);
    color: var(--text-secondary);
    background: rgba(134, 116, 244, 0.02);
  }

  .project-links {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
    border-top: 1px solid var(--border-color);
    padding-top: 1rem;
  }

  .link-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    background: transparent;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .link-btn:hover {
    color: var(--text-primary);
    border-color: var(--accent-violet);
    background: rgba(134, 116, 244, 0.05);
  }

  .demo-btn {
    background: rgba(134, 116, 244, 0.1);
    border-color: rgba(134, 116, 244, 0.2);
    color: var(--accent-violet-hover);
  }

  .demo-btn:hover {
    background: var(--accent-violet);
    color: #ffffff;
    border-color: var(--accent-violet);
    box-shadow: 0 4px 12px rgba(134, 116, 244, 0.2);
  }
</style>
